{
  "name": "oauth-test-demo-app",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-27",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/*", "!/assets/*"]
  },
  "version_metadata": {
    "binding": "METADATA"
  }
}
